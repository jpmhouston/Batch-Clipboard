                        <textField focusRingType="none" horizontalHuggingPriority="251" verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="Ymg-HB-wY8">
                            <rect key="frame" x="-2" y="184" width="560" height="57"/>
                            <textFieldCell key="cell" id="6Lg-hC-5kS">
                                <font key="font" metaFont="system" size="15"/>
                                <string key="title">You can enter _batch mode_ manually using **Start Batch** in the menu, or by control-clicking on the menu icon. Then instead of ^⌘C, any Copy or Cut command in your application will add clips into the batch.</string>
                                <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                            </textFieldCell>
                        </textField>
                        <textField focusRingType="none" horizontalHuggingPriority="251" verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="LE6-xs-MT8">
                            <rect key="frame" x="-2" y="112" width="560" height="57"/>
                            <textFieldCell key="cell" id="jgc-sX-7Ob">
                                <font key="font" metaFont="system" size="15"/>
                                <string key="title">After copying, you can manually begin pasting with the **Start Replaying Items** menu item. You can then use your app's Paste command instead of ^⌘V, but to advance to the next clip you must use the **Skip to Next** menu item.</string>
                                <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                            </textFieldCell>
                        </textField>
                        <textField focusRingType="none" horizontalHuggingPriority="251" verticalHuggingPriority="750" translatesAutoresizingMaskIntoConstraints="NO" id="0au-Bd-kFz">
                            <rect key="frame" x="-2" y="39" width="560" height="57"/>
                            <textFieldCell key="cell" id="rfB-4h-t9g">
                                <font key="font" metaFont="system" size="15"/>
                                <string key="title">When in _batch mode_ clipboard items that have been collected and not yet pasted are shown in the Batch Clipboard menu, the next one to paste at the top. You can delete an item you copied accidentally with ⌘-Delete.</string>
                                <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
                            </textFieldCell>
                        </textField>
                        <stackView distribution="fill" orientation="horizontal" alignment="firstBaseline" spacing="16" horizontalStackHuggingPriority="249.99998474121094" verticalStackHuggingPriority="249.99998474121094" detachesHiddenViews="YES" translatesAutoresizingMaskIntoConstraints="NO" id="paB-zZ-lX6">
